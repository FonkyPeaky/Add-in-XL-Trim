<local:GlassWindow
    x:Class="XLTrim.UI.ScanDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:XLTrim.UI"
    Title="XL Trim" Height="580" Width="660"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="False"
    Background="#1E2638"
    ResizeMode="NoResize"
    Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#0AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#18FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="#4F46E5"
                                CornerRadius="8"
                                Padding="0,13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5B54F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4338CA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#55FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="0,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0DFFFFFF"/>
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="spinRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.2"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#1E2638" BorderThickness="0" CornerRadius="0" ClipToBounds="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#356366F1" Offset="0"/>
                    <GradientStop Color="#1522D3EE" Offset="0.5"/>
                    <GradientStop Color="#356366F1" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <!-- Reflet haut -->
                <Border Height="1" VerticalAlignment="Top" Margin="60,0" CornerRadius="24,24,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Zone drag -->
                <Border x:Name="titleBar" Height="50" VerticalAlignment="Top"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

                <!-- Fermer -->
                <Button Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,10,14,0" Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="4">
                                <TextBlock Text="✕" FontSize="11" Foreground="#44FFFFFF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#15FF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Grid Margin="36,16,36,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="XL Trim" FontSize="18" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtSubtitle" Text="Scanning..."
                                   FontSize="12" Foreground="#55FFFFFF"/>
                    </StackPanel>

                    <!-- ═══ STATE 1 : Scan en cours ═══════════════════════ -->
                    <Grid x:Name="panelScanning" Grid.Row="1" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Ellipse Width="70" Height="70"
                                         Stroke="#15FFFFFF" StrokeThickness="3" Fill="Transparent"/>
                                <Ellipse x:Name="spinRing" Width="70" Height="70"
                                         StrokeThickness="3" Fill="Transparent"
                                         StrokeDashArray="5 15" StrokeDashCap="Round"
                                         StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#06B6D4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                    </Ellipse.Effect>
                                    <Ellipse.RenderTransform>
                                        <RotateTransform/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <TextBlock Text="Scanning..." FontSize="14" Foreground="#77FFFFFF"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- ═══ STATE 2 : Résultats ═══════════════════════════ -->
                    <Grid x:Name="panelResults" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Ligne 1 : 3 cartes -->
                        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,10">
                            <Border x:Name="card1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                                <Border.RenderTransform><TranslateTransform Y="16"/></Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="STYLES MAX ID" FontSize="9" FontWeight="Bold"
                                               Foreground="#44FFFFFF" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="numStylesMaxId" Text="—"
                                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                                    <Border x:Name="dotStylesMaxId" Width="6" Height="6" CornerRadius="3"
                                            Background="#6366F1" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="card2" Style="{StaticResource StatCard}" Margin="4,0">
                                <Border.RenderTransform><TranslateTransform Y="16"/></Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="STYLES NODES" FontSize="9" FontWeight="Bold"
                                               Foreground="#44FFFFFF" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="numStylesCount" Text="—"
                                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                                    <Border x:Name="dotStylesCount" Width="6" Height="6" CornerRadius="3"
                                            Background="#6366F1" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="card3" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                                <Border.RenderTransform><TranslateTransform Y="16"/></Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="NAMED RANGES" FontSize="9" FontWeight="Bold"
                                               Foreground="#44FFFFFF" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="numDefinedRanges" Text="—"
                                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                                    <Border x:Name="dotDefinedRanges" Width="6" Height="6" CornerRadius="3"
                                            Background="#6366F1" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    </Border>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Ligne 2 : 2 cartes + score santé -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="card4" Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                                <Border.RenderTransform><TranslateTransform Y="16"/></Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="INVALID RANGES" FontSize="9" FontWeight="Bold"
                                               Foreground="#44FFFFFF" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="numInvalidRanges" Text="—"
                                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                                    <Border x:Name="dotInvalidRanges" Width="6" Height="6" CornerRadius="3"
                                            Background="#EF4444" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="card5" Grid.Column="1" Style="{StaticResource StatCard}" Margin="4,0">
                                <Border.RenderTransform><TranslateTransform Y="16"/></Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="HIDDEN RANGES" FontSize="9" FontWeight="Bold"
                                               Foreground="#44FFFFFF" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="numHiddenRanges" Text="—"
                                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                                    <Border x:Name="dotHiddenRanges" Width="6" Height="6" CornerRadius="3"
                                            Background="#F59E0B" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Score santé -->
                            <Border x:Name="card6" Grid.Column="2"
                                    Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1"
                                    CornerRadius="16" Padding="18,16" Margin="8,0,0,0" Opacity="0">
                                <Border.RenderTransform><TranslateTransform Y="16"/></Border.RenderTransform>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="HEALTH" FontSize="9" FontWeight="Bold"
                                               Foreground="#44FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="txtHealthScore" Text="—" FontSize="32" FontWeight="Black"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#EF4444" Offset="0"/>
                                                <GradientStop Color="#F59E0B" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock x:Name="txtHealthLabel" Text="critical" FontSize="11"
                                               Foreground="#55FFFFFF" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ═══ STATE 3 : Nettoyage ═══════════════════════════ -->
                    <Grid x:Name="panelCleaning" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse Width="90" Height="90"
                                         Stroke="#15FFFFFF" StrokeThickness="6" Fill="Transparent"/>
                                <Ellipse x:Name="progressRing" Width="90" Height="90"
                                         StrokeThickness="6" Fill="Transparent"
                                         StrokeDashCap="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                         StrokeDashArray="0 1000"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#06B6D4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                                    </Ellipse.Effect>
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <TextBlock x:Name="txtProgressPct" Text="0%"
                                           FontSize="18" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock x:Name="txtCleanStatus" Text="Initializing..."
                                       FontSize="13" Foreground="#77FFFFFF" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- ═══ STATE 4 : Terminé ═════════════════════════════ -->
                    <Grid x:Name="panelDone" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Ellipse>
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#3010B981" Offset="0"/>
                                            <GradientStop Color="#0010B981" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#10B981" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="✓" FontSize="36" FontWeight="Bold" Foreground="#10B981"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Cleanup complete!" FontSize="18" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtDoneSummary" FontSize="12" Foreground="#66FFFFFF"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── Footer ─────────────────────────────────────── -->
                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <Border Height="1" Margin="0,0,0,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#12FFFFFF" Offset="0.5"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnClose" Grid.Column="0"
                                    Content="Close" Style="{StaticResource GhostBtn}"
                                    Click="CloseButton_Click"/>
                            <Button x:Name="btnClean" Grid.Column="2"
                                    Content="Clean File"
                                    Style="{StaticResource ActionButton}"
                                    IsEnabled="False"
                                    Click="CleanButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
    </Border>
</local:GlassWindow>
