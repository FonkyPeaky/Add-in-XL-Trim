<local:GlassWindow
    x:Class="XLTrim.UI.BackupDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:XLTrim.UI"
    Title="XL Trim — Backup" Height="460" Width="400"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="False"
    Background="#1E2638"
    ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="CyanGlowButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="#4F46E5"
                                CornerRadius="8"
                                Padding="0,14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5B54F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4338CA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="#55FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="0,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0DFFFFFF"/>
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Carte -->
    <Border Background="#1E2638" BorderThickness="0" CornerRadius="0" ClipToBounds="True">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#406366F1" Offset="0"/>
                    <GradientStop Color="#2022D3EE" Offset="0.5"/>
                    <GradientStop Color="#406366F1" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <!-- Reflet haut -->
                <Border Height="1" VerticalAlignment="Top" Margin="40,0" CornerRadius="22,22,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#25FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Zone drag -->
                <Border x:Name="titleBar" Height="50" VerticalAlignment="Top"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

                <!-- Bouton fermer -->
                <Button Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,10,12,0"
                        Click="CloseButton_Click"
                        Style="{StaticResource GhostButton}">
                    <TextBlock Text="✕" FontSize="11" Foreground="#44FFFFFF"/>
                </Button>

                <!-- Contenu -->
                <StackPanel Margin="36,20,36,32" VerticalAlignment="Center">

                    <!-- Icône -->
                    <Grid Width="84" Height="84" HorizontalAlignment="Center" Margin="0,10,0,24">
                        <Ellipse>
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#3006B6D4" Offset="0"/>
                                    <GradientStop Color="#0006B6D4" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#06B6D4" BlurRadius="24" ShadowDepth="0" Opacity="0.6"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="68" Height="68" Stroke="#3006B6D4" StrokeThickness="1"/>
                        <TextBlock Text="💾" FontSize="34"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Title -->
                    <TextBlock Text="Create a backup?"
                               FontSize="21" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- Subtitle -->
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               FontSize="13" Foreground="#77FFFFFF" LineHeight="20" Margin="0,0,0,22">
                        Before cleaning, we recommend saving&#x0a;a backup of your file just in case.
                    </TextBlock>

                    <!-- Pill fichier -->
                    <Border Background="#0AFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1"
                            CornerRadius="20" Padding="14,6"
                            HorizontalAlignment="Center" Margin="0,0,0,28">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄 " FontSize="11" Foreground="#44FFFFFF"/>
                            <TextBlock x:Name="txtFileName" FontSize="11" Foreground="#66FFFFFF"
                                       MaxWidth="260" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- Primary button -->
                    <Button Content="Create backup"
                            Style="{StaticResource CyanGlowButton}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,10"
                            Click="BackupButton_Click"/>

                    <!-- Secondary button -->
                    <Button Content="Continue without backup"
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Stretch"
                            Click="SkipButton_Click"/>
                </StackPanel>
            </Grid>
    </Border>
</local:GlassWindow>
